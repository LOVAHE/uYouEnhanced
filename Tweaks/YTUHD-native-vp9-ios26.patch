diff --git a/Tweak.xm b/Tweak.xm
index 7c592e3..f8c3019 100644
--- a/Tweak.xm
+++ b/Tweak.xm
@@ -1,3 +1,6 @@
+#import <CoreMedia/CoreMedia.h>
+#import <VideoToolbox/VideoToolbox.h>
+#import <dlfcn.h>
 #import <substrate.h>
 #import <sys/sysctl.h>
 #import <version.h>
@@ -18,6 +21,39 @@ NSArray <MLFormat *> *filteredFormats(NSArray <MLFormat *> *formats) {
     return formats;
 }
 
+static BOOL YTUHDSystemHasModernNativeVP9(void) {
+    NSOperatingSystemVersion version =
+        NSProcessInfo.processInfo.operatingSystemVersion;
+    return version.majorVersion > 26 ||
+        (version.majorVersion == 26 && version.minorVersion >= 2);
+}
+
+static void YTUHDRegisterNativeVP9IfAvailable(void) {
+    if (!YTUHDSystemHasModernNativeVP9()) return;
+
+    typedef void (*RegisterSupplementalDecoderFn)(CMVideoCodecType);
+    RegisterSupplementalDecoderFn registerDecoder =
+        (RegisterSupplementalDecoderFn)dlsym(
+            RTLD_DEFAULT,
+            "VTRegisterSupplementalVideoDecoderIfAvailable"
+        );
+    if (!registerDecoder) {
+        void *videoToolbox = dlopen(
+            "/System/Library/Frameworks/VideoToolbox.framework/VideoToolbox",
+            RTLD_LAZY | RTLD_LOCAL
+        );
+        if (videoToolbox) {
+            registerDecoder = (RegisterSupplementalDecoderFn)dlsym(
+                videoToolbox,
+                "VTRegisterSupplementalVideoDecoderIfAvailable"
+            );
+        }
+    }
+    if (registerDecoder) {
+        registerDecoder(kCMVideoCodecType_VP9);
+    }
+}
+
 static void hookFormatsBase(YTIHamplayerConfig *config) {
     if ([config.videoAbrConfig respondsToSelector:@selector(setPreferSoftwareHdrOverHardwareSdr:)])
         config.videoAbrConfig.preferSoftwareHdrOverHardwareSdr = YES; // Removed in YouTube 19.22.3
@@ -198,6 +234,7 @@ static void hookFormatsBase(YTIHamplayerConfig *config) {
 %end
 
 %ctor {
+    YTUHDRegisterNativeVP9IfAvailable();
     [[NSUserDefaults standardUserDefaults] registerDefaults:@{
         DecodeThreadsKey: @2
     }];
